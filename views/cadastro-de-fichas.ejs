<!doctype html>
<html lang="pt-BR">
  <%- include('partials/head') %>
  <body>
    <%- include('partials/navbar') %>

    <div class="container">
      <h1>Cadastro de Fichas</h1>
      <form id="form-ficha" class="form-ficha">
        <div class="form-group">
          <label>Nome</label
          ><input type="text" id="nome" name="nome" maxlength="100" />
        </div>
        <div class="form-group">
          <label>Email</label><input type="email" id="email" name="email" />
        </div>
        <div class="form-group">
          <label>Peso (kg)</label
          ><input type="number" id="peso" name="peso" max="200" min="0" />
        </div>
        <div class="form-group">
          <label>Peito (cm)</label
          ><input type="number" id="peito" name="peito" max="200" min="0" />
        </div>
        <div class="form-group">
          <label>Abdômen (cm)</label
          ><input type="number" id="abdomen" name="abdomen" max="200" min="0" />
        </div>
        <div class="form-group">
          <label>Ombros (cm)</label
          ><input type="number" id="ombros" name="ombros" max="200" min="0" />
        </div>
        <div class="form-group">
          <label>Quadríceps Esquerdo (cm)</label
          ><input
            type="number"
            id="quadriceps-esquerdo"
            name="quadricepsEsquerdo"
            max="200"
            min="0"
          />
        </div>
        <div class="form-group">
          <label>Quadríceps Direito (cm)</label
          ><input
            type="number"
            id="quadriceps-direito"
            name="quadricepsDireito"
            max="200"
            min="0"
          />
        </div>
        <div class="form-group">
          <label>Panturrilha Esquerda (cm)</label
          ><input
            type="number"
            id="panturrilha-esquerda"
            name="panturrilhaEsquerda"
            max="200"
            min="0"
          />
        </div>
        <div class="form-group">
          <label>Panturrilha Direita (cm)</label
          ><input
            type="number"
            id="panturrilha-direita"
            name="panturrilhaDireita"
            max="200"
            min="0"
          />
        </div>
        <div class="form-group">
          <label>Bíceps Esquerdo (cm)</label
          ><input
            type="number"
            id="biceps-esquerdo"
            name="bicepsEsquerdo"
            max="200"
            min="0"
          />
        </div>
        <div class="form-group">
          <label>Bíceps Direito (cm)</label
          ><input
            type="number"
            id="biceps-direito"
            name="bicepsDireito"
            max="200"
            min="0"
          />
        </div>
        <button id="btn-salvar" class="btn">Salvar</button>
      </form>
    </div>

    <%- include('partials/scripts') %>
  </body>
</html>
